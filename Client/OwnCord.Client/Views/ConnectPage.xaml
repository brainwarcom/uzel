<Page x:Class="OwnCord.Client.Views.ConnectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Connect">

    <Page.Resources>
        <!-- TOTP digit TextBox (ConnectPage-specific) -->
        <Style x:Key="TotpDigitBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextNormal}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="MaxLength" Value="1"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextNormal}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BgPrimary}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Settings gear (top-right) -->
        <Button Grid.ColumnSpan="3" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,16,16,0" Width="36" Height="36" Cursor="Hand" ToolTip="Settings"
                Panel.ZIndex="10">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="8" Background="Transparent"
                            Width="36" Height="36">
                        <TextBlock Text="&#x2699;" FontSize="20" Foreground="#80848e"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   x:Name="Icon"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#35373c"/>
                            <Setter TargetName="Icon" Property="Foreground" Value="#dbdee1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Left panel: Saved servers -->
        <Border Grid.Column="0" Background="#2b2d31" Padding="0"
                BorderThickness="0,0,1,0" BorderBrush="#1e1f22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="20,20,20,12" BorderBrush="#3f4147" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="YOUR SERVERS" FontSize="11" FontWeight="Bold"
                                   Foreground="#80848e" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="&#x21bb;" FontSize="14" FontWeight="Bold"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding RefreshHealthCommand}"
                                    ToolTip="Refresh server health" Margin="0,0,4,0"/>
                            <Button Content="+" FontSize="16" FontWeight="Bold"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding AddProfileCommand}"
                                    ToolTip="Add server"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Server list -->
                <ListBox Grid.Row="1" x:Name="ProfileList"
                         ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Padding="8,8,8,0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="6" Margin="0,1" Padding="12,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Server icon circle with profile color and first letter -->
                                                <Grid Grid.Column="0" Width="36" Height="36" Margin="0,0,12,0">
                                                    <Border Width="36" Height="36"
                                                            CornerRadius="18"
                                                            Background="{Binding Color, Converter={StaticResource ColorToBrush}}">
                                                        <Grid>
                                                            <TextBlock Text="{Binding Name, Converter={StaticResource FirstChar}}"
                                                                       FontSize="15" FontWeight="Bold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                            <!-- Auto-connect indicator -->
                                                            <TextBlock Text="&#x26A1;" FontSize="10"
                                                                       HorizontalAlignment="Right"
                                                                       VerticalAlignment="Bottom"
                                                                       Margin="0,0,-2,0"
                                                                       Visibility="{Binding AutoConnect, Converter={StaticResource BoolToVisibility}}"/>
                                                        </Grid>
                                                    </Border>
                                                    <!-- Health status dot -->
                                                    <Ellipse x:Name="HealthDot" Width="10" Height="10"
                                                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                             Margin="0,0,-1,-1"
                                                             Stroke="#2b2d31" StrokeThickness="2"/>
                                                </Grid>

                                                <!-- Server name + host:port + last connected -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="14"
                                                               FontWeight="SemiBold" Foreground="#dbdee1"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding HostDisplay}" FontSize="12"
                                                               Foreground="#949ba4" Margin="0,1,0,0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding LastConnected, Converter={StaticResource RelativeTime}}"
                                                               FontSize="11" Foreground="#6d6f78"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>

                                                <!-- Edit + Delete buttons -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            x:Name="ActionButtons" Visibility="Collapsed">
                                                    <Button Content="&#x270E;"
                                                            Style="{StaticResource EditButton}"
                                                            Click="EditProfile_Click"
                                                            Tag="{Binding}"/>
                                                    <Button Content="X"
                                                            Style="{StaticResource DangerButton}"
                                                            Click="DeleteProfile_Click"
                                                            Tag="{Binding}" Margin="4,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#35373c"/>
                                                <Setter TargetName="ActionButtons" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#404249"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="ActionButtons" Property="Visibility" Value="Visible"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Empty state -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasNoProfiles, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="No saved servers" FontSize="14" Foreground="#4e5058"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Add a server to get started" FontSize="12"
                               Foreground="#3f4147" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Footer: Save current + Import/Export -->
                <Border Grid.Row="2" Padding="12" BorderBrush="#3f4147" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Content="+ Save Current Server"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding SaveProfileCommand}"
                                HorizontalAlignment="Stretch"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,6,0,0">
                            <Button Content="Import" Style="{StaticResource SmallIconButton}"
                                    Command="{Binding ImportProfilesCommand}"
                                    ToolTip="Import profiles from JSON" Margin="0,0,4,0"/>
                            <Button Content="Export" Style="{StaticResource SmallIconButton}"
                                    Command="{Binding ExportProfilesCommand}"
                                    ToolTip="Export profiles to JSON"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- (divider handled by left panel border) -->

        <!-- Right panel: Login form / TOTP -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="340" Padding="0,40">
                <Grid>
                    <!-- Login/Register form (hidden during 2FA) -->
                    <StackPanel Visibility="{Binding IsTotpRequired, Converter={StaticResource InverseBoolToVisibility}}">
                        <!-- Logo / Title -->
                        <TextBlock Text="OwnCord" FontSize="28" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Welcome back!" FontSize="14"
                                   Foreground="#b5bac1" HorizontalAlignment="Center"
                                   Margin="0,4,0,32"
                                   Visibility="{Binding IsRegisterMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                        <TextBlock Text="Create an account" FontSize="14"
                                   Foreground="#b5bac1" HorizontalAlignment="Center"
                                   Margin="0,4,0,32"
                                   Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Error message -->
                        <Border Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                                Background="#2d1214" CornerRadius="4" Padding="12,10" Margin="0,0,0,16">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#f38688"
                                       TextWrapping="Wrap" FontSize="13"/>
                        </Border>

                        <!-- Host + Port row -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Column="0" Grid.Row="0" Text="SERVER ADDRESS"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#b5bac1" Margin="0,0,0,6"/>
                            <TextBox Grid.Column="0" Grid.Row="1"
                                     Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>

                            <TextBlock Grid.Column="2" Grid.Row="0" Text="PORT"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#b5bac1" Margin="0,0,0,6"/>
                            <TextBox Grid.Column="2" Grid.Row="1" x:Name="PortBox"
                                     Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </Grid>

                        <!-- Username -->
                        <TextBlock Text="USERNAME" FontSize="11" FontWeight="Bold"
                                   Foreground="#b5bac1" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                        <!-- Password -->
                        <TextBlock Text="PASSWORD" FontSize="11" FontWeight="Bold"
                                   Foreground="#b5bac1" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,10"/>

                        <!-- Save password -->
                        <CheckBox Content="Remember my password" Style="{StaticResource ModernCheckBox}"
                                  IsChecked="{Binding SavePassword}" Margin="0,0,0,16"/>

                        <!-- Invite code (register mode only) -->
                        <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibility}}"
                                    Margin="0,0,0,16">
                            <TextBlock Text="INVITE CODE" FontSize="11" FontWeight="Bold"
                                       Foreground="#b5bac1" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding InviteCode, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <!-- Connect button -->
                        <Button Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                Click="ConnectButton_Click">
                            <Button.Content>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Log In"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRegisterMode}" Value="True">
                                                    <Setter Property="Text" Value="Register"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                    <Setter Property="Text" Value="Connecting..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>

                        <!-- Switch to Register -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                    Visibility="{Binding IsRegisterMode, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Text="Need an account? " FontSize="13" Foreground="#80848e"/>
                            <Button Content="Register" Style="{StaticResource LinkButton}"
                                    Click="SwitchToRegister_Click"/>
                        </StackPanel>

                        <!-- Switch to Login -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                    Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Already have an account? " FontSize="13" Foreground="#80848e"/>
                            <Button Content="Log In" Style="{StaticResource LinkButton}"
                                    Click="SwitchToLogin_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 2FA TOTP entry (visible only during 2FA) -->
                    <StackPanel Visibility="{Binding IsTotpRequired, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Two-Factor Authentication" FontSize="22" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Enter the 6-digit code from your authenticator app"
                                   FontSize="13" Foreground="#949ba4" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,28"/>

                        <!-- Error message -->
                        <Border Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                                Background="#2d1214" CornerRadius="4" Padding="12,10" Margin="0,0,0,16">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#f38688"
                                       TextWrapping="Wrap" FontSize="13"/>
                        </Border>

                        <!-- 6 digit boxes -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                            <TextBox x:Name="Totp1" Style="{StaticResource TotpDigitBox}" Margin="0,0,6,0"
                                     TextChanged="TotpDigit_TextChanged" PreviewKeyDown="TotpDigit_KeyDown"
                                     PreviewTextInput="TotpDigit_PreviewTextInput"/>
                            <TextBox x:Name="Totp2" Style="{StaticResource TotpDigitBox}" Margin="0,0,6,0"
                                     TextChanged="TotpDigit_TextChanged" PreviewKeyDown="TotpDigit_KeyDown"
                                     PreviewTextInput="TotpDigit_PreviewTextInput"/>
                            <TextBox x:Name="Totp3" Style="{StaticResource TotpDigitBox}" Margin="0,0,6,0"
                                     TextChanged="TotpDigit_TextChanged" PreviewKeyDown="TotpDigit_KeyDown"
                                     PreviewTextInput="TotpDigit_PreviewTextInput"/>
                            <TextBox x:Name="Totp4" Style="{StaticResource TotpDigitBox}" Margin="0,0,6,0"
                                     TextChanged="TotpDigit_TextChanged" PreviewKeyDown="TotpDigit_KeyDown"
                                     PreviewTextInput="TotpDigit_PreviewTextInput"/>
                            <TextBox x:Name="Totp5" Style="{StaticResource TotpDigitBox}" Margin="0,0,6,0"
                                     TextChanged="TotpDigit_TextChanged" PreviewKeyDown="TotpDigit_KeyDown"
                                     PreviewTextInput="TotpDigit_PreviewTextInput"/>
                            <TextBox x:Name="Totp6" Style="{StaticResource TotpDigitBox}"
                                     TextChanged="TotpDigit_TextChanged" PreviewKeyDown="TotpDigit_KeyDown"
                                     PreviewTextInput="TotpDigit_PreviewTextInput"/>
                        </StackPanel>

                        <!-- Verify button -->
                        <Button Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                Click="VerifyTotp_Click">
                            <Button.Content>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Verify"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                    <Setter Property="Text" Value="Verifying..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>

                        <!-- Back button -->
                        <Button Content="Back to login" Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Center" Margin="0,8,0,0"
                                Command="{Binding CancelTotpCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
